    "shots": [
      {
        "id": "shot01_night_lesson",
        "duration_s": 18,
        "story_goal": "建立哥哥曾经教给少年的核心观念：不要急着证明自己，要等待节奏回来再出拳。",
        "start_state": "夜晚旧拳馆里，年少的他站在旧沙袋前双拳抬高，哥哥站在身后用缠旧绷带的手按住他的肩膀，昏黄顶灯照着两人。",
        "end_state": "少年拳势放低一些，沙袋回到他面前，哥哥的手仍稳稳按在他的肩上，两人面对同一个沙袋，拳馆夜色安静。",
        "visual_intent": "以低位平视的缓慢手持跟拍维持亲密距离，节奏从少年急促到被哥哥压住后放慢，写实回忆质感，暖黄顶光与深棕阴影形成旧照片般的色彩。"
      },
      {
        "id": "shot02_memory_details",
        "duration_s": 6,
        "story_goal": "用细节把回忆固定成一组能影响现在的符号：拳台、沙袋、哥哥的手和未完成的职业赛梦想。",
        "start_state": "旧拳台围绳横在前景，摇晃后的沙袋偏在一侧，哥哥缠着旧绷带的手靠在围绳旁，墙上职业赛海报仍然崭新。",
        "end_state": "崭新的职业赛海报占据墙面中心，哥哥缠旧绷带的手在画面边缘虚化，夜晚顶灯的暖光停在海报纸面上。",
        "visual_intent": "镜头做短促的横向扫视与轻微拉焦，像记忆碎片依次掠过，节奏短而柔，风格克制怀旧，色彩保持暖黄与暗红拳台元素。"
      },
      {
        "id": "shot03_morning_setup",
        "duration_s": 18,
        "story_goal": "回到现在，说明他在哥哥缺席的清晨独自完成赛前最后训练，并把三分钟倒计时和旧口令引入当下。",
        "start_state": "清晨空荡旧拳馆里，旧沙袋底部在前景，年轻拳手站在沙袋后方，右眼肿起，双手缠满胶布，墙上计时器显示三分钟。",
        "end_state": "年轻拳手的肿起右眼、缠胶布的手和发黄旧比赛海报同在画面层次里，旧录音机放在一侧，拳馆里没有教练。",
        "visual_intent": "镜头从沙袋底部缓慢抬升到人物面部与手，再带到海报和计时器，动作极慢，写实纪实风格，清晨灰蓝光压住回忆的暖色，只保留少量旧顶灯余温。"
      },
      {
        "id": "shot04_losing_rhythm",
        "duration_s": 38,
        "story_goal": "表现他把恐惧误认为必须打碎的敌人，因不听哥哥的口令而失去节奏，并被沙袋反弹击溃。",
        "start_state": "年轻拳手右眼青肿，右拳停在胸前偏低位置，双脚站得过窄，面对旧沙袋，地板上已有汗水和漏雨水迹，旧录音机在后方。",
        "end_state": "旧沙袋压在年轻拳手胸前，他膝盖弯低，右眼青肿，双手胶布湿透，地板汗水滴痕与漏雨水迹混在一起。",
        "visual_intent": "坚持不切走的手持近距离跟拍，先让出拳频率逐段加快，再让脚步和右手高度出现失控，沙袋反弹时节奏突变但镜头仍贴着人物呼吸，风格粗粝写实，冷灰色调中保留汗水高光。"
      },
      {
        "id": "shot05_find_rhythm",
        "duration_s": 45,
        "story_goal": "让他从挫败中理解哥哥留下的话，不再用重拳对抗恐惧，而是通过等待、侧身和左刺拳重新找回自己的节奏。",
        "start_state": "年轻拳手右眼青肿，胸口贴近旧沙袋，一手扶着沙袋，肩背微弯但双脚重新稳住，汗水和漏雨水迹在脚边发亮。",
        "end_state": "年轻拳手右眼仍肿，双手胶布湿透，身体侧向旧沙袋，左拳停在准确距离上，脚步稳定，镜墙里只映出他一个人的身影。",
        "visual_intent": "镜头由近身颤动逐渐稳定，围绕他和沙袋做小幅弧形移动，节奏从喘息空拍过渡到均匀的刺拳、等待、侧身，录音机卡带感与呼吸节拍重合，风格写实克制，清晨冷光逐渐变亮。"
      },
      {
        "id": "shot06_bell_zero",
        "duration_s": 4,
        "story_goal": "用倒计时归零标记这轮训练结束，也标记他从替哥哥证明转向听见自己的呼吸。",
        "start_state": "墙上计时器红色数字归零，年轻拳手在虚焦中侧身面对沙袋，右眼青肿，双手胶布湿透，身体停在稳定站姿。",
        "end_state": "计时器仍停在归零状态，年轻拳手的身体在背景里放松下来，旧沙袋轻轻偏在他面前，空荡拳馆保持安静。",
        "visual_intent": "短促静止镜头，几乎不移动，只让铃声和人物微小放松成为冲击点，节奏骤停，写实极简，冷白晨光强调红色数字的终止感。"
      },
      {
        "id": "shot07_aftermath",
        "duration_s": 24,
        "story_goal": "完成情感落点：他接受今晚可能会输，却把哥哥的遗留物带上路，以自己的节奏走向职业擂台。",
        "start_state": "年轻拳手右眼青肿，额头靠在旧沙袋上，拳套仍戴着，双肩放松，空荡拳馆和逐渐亮起的窗户在后方。",
        "end_state": "年轻拳手摘下旧拳套站在发黄比赛海报前，哥哥的旧绷带已塞进半开的运动包，清晨光照亮空荡拳馆。",
        "visual_intent": "镜头先缓慢后退露出拳馆空间，再平稳跟随他走向海报墙，节奏安静留白，写实纪实风格，色彩由冷灰逐渐过渡到柔和晨白，氛围克制而释然。"
      }
    ],
