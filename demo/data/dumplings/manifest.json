    "shots": [
      {
        "id": "shot01_new_year_kitchen",
        "duration_s": 28,
        "story_goal": "建立除夕夜父女久别重逢却疏离的关系基底，以及旧厨房作为家庭记忆容器的核心位置。",
        "start_state": "父亲与女儿并肩站在窄厨房案板前，案板上有面粉、清水碗、馅盆和几排饺子；父亲双手捧着饺子皮，女儿低头捏饺子，目光避开父亲。",
        "end_state": "父亲手边多了几个褶子细密的饺子，女儿面前也排出几只饺子；两人仍并肩站着，身体距离很近，视线始终没有真正相接。",
        "visual_intent": "长镜头缓慢横移并轻微推近，从案板面粉扫到两人手部再停在并肩关系上，节奏克制缓慢，写实家庭纪实风格，氛围安静疏离，暖黄厨房光中掺入远处电视冷蓝色。"
      },
      {
        "id": "shot02_wrapped_wrong",
        "duration_s": 12,
        "story_goal": "通过父亲不直接询问、只提醒馅料多少，以及女儿捏歪饺子的细节，呈现两人无法开口的关心与抗拒。",
        "start_state": "父亲的手把擀好的饺子皮放在女儿手边，女儿低头接住，清水碗在案板右后方，父亲没有看她的脸。",
        "end_state": "女儿面前有一个捏歪的饺子，清水碗被父亲推近到她手边；女儿手指停在碗旁，重新蘸水后的饺子边缘被捏紧。",
        "visual_intent": "镜头固定在手部近景，偶尔微小拉焦从饺子皮转到清水碗，节奏细腻缓慢，写实电影感，氛围含蓄尴尬，色彩维持低饱和暖黄。"
      },
      {
        "id": "shot03_time_traces",
        "duration_s": 24,
        "story_goal": "揭示厨房中未被处理的旧物与母亲缺席，使女儿卖房的理由从现实安全问题转向对停滞记忆的抵触。",
        "start_state": "女儿低头把包好的饺子排到盘子边缘，父亲取馅时身体避开窗台上的旧搪瓷杯；墙上褪色照片和停摆挂钟清晰可见。",
        "end_state": "女儿面前的饺子被排成整齐一列，她的嘴角紧绷，父亲仍低头包饺子；搪瓷杯、旧照片和停摆挂钟都留在两人背后。",
        "visual_intent": "镜头从案板慢慢摇向墙面旧物，再回到女儿低头的侧脸，节奏逐步收紧，写实纪实风格，氛围由沉默转为冷硬，暖黄旧灯和冷蓝窗光制造记忆与现实的分裂。"
      },
      {
        "id": "shot04_cold_voice_crack",
        "duration_s": 6,
        "story_goal": "让争执达到最冷的一刻：女儿指出小修补无法解决问题，父亲的退让以破裂的饺子皮显形。",
        "start_state": "父亲手中的饺子皮边缘出现细小裂口，女儿停在案板另一侧，脸转向贴胶带的窗缝，神情冷硬。",
        "end_state": "父亲把裂开的饺子皮重新摊平在掌心，低着头没有看女儿；女儿双手停在盘子边，贴胶带的窗缝在她身后发冷光。",
        "visual_intent": "短镜头以手持轻微颤动贴近父亲手部，再用一次冷静拉焦落到女儿侧脸，节奏突然变短变硬，写实手持电影风格，氛围压抑，冷蓝窗光短暂压过暖黄灯。"
      },
      {
        "id": "shot05_mothers_folds",
        "duration_s": 18,
        "story_goal": "让母亲的记忆通过饺子褶纹回到现场，促成女儿从抗拒转向主动修补的第一步。",
        "start_state": "父亲把自己包得最好的饺子放在女儿那边，那个褶子整齐的饺子旁边是她先前捏歪的饺子，女儿低头凝视。",
        "end_state": "女儿把先前捏歪的饺子重新捏好，褶子的顺序接近父亲放来的那只；两只饺子并排在她面前，父亲的手停得更慢。",
        "visual_intent": "镜头以85mm近景凝视饺子褶纹，缓慢推近并停留在女儿手指，节奏柔和延长，写实电影感，氛围从僵硬转为隐秘的亲近，暖黄光集中在面粉和褶纹上。"
      },
      {
        "id": "shot06_height_mark_touch",
        "duration_s": 7,
        "story_goal": "通过门框身高刻痕让女儿重新触碰自己曾属于这个家的证据，使卖房议题出现松动。",
        "start_state": "女儿沾着面粉的手指贴近门框最高的铅笔刻痕，母亲字迹在旁边可见；父亲在案板旁虚化，动作放慢。",
        "end_state": "女儿指尖留下淡淡面粉印，最高刻痕没有被擦掉；她侧脸安静，父亲仍在身后默默站着。",
        "visual_intent": "镜头静止近景，利用窗外提前鞭炮造成的轻微玻璃震动带出环境反应，节奏短而停顿，写实克制，氛围柔软但不煽情，暖黄门框与冷蓝客厅光交界。"
      },
      {
        "id": "shot07_boiling_together",
        "duration_s": 22,
        "story_goal": "让父女从并肩但各自沉默，转为在煮饺子的具体动作中重新形成配合。",
        "start_state": "灶上锅水开始沸腾，父亲站在锅前拿着装饺子的盘子，女儿站在旁边空着手，身体比先前更靠近灶台。",
        "end_state": "锅里饺子在热水中浮动，女儿手持漏勺停在锅边，父亲的手离开调小后的火力旋钮；锅盖被斜放在一侧，蒸汽从缝隙上升。",
        "visual_intent": "镜头围绕灶台小幅弧形移动，从父亲下锅的手到女儿接过漏勺，节奏由谨慎到协调，写实家庭纪实风格，氛围逐渐亲密，蒸汽柔化旧厨房痕迹，暖黄灶灯穿透白雾。"
      },
      {
        "id": "shot08_quiet_aftertaste",
        "duration_s": 16,
        "story_goal": "以女儿提出先修厨房窗户而非继续卖房，完成关系暂时和解但不彻底解决的余韵。",
        "start_state": "女儿碗里盛着那只重新捏好的饺子，饺子浮在热汤白雾中；女儿低头看碗，父亲站在灶旁，手靠近煤气旋钮。",
        "end_state": "空盘子上还剩一点面粉，门框刻痕没有被擦掉，父亲和女儿并肩站在灶台前，锅里的热气安静上升。",
        "visual_intent": "镜头从碗中饺子缓慢拉远到父女并肩和旧厨房全貌，节奏舒缓留白，写实电影感，氛围克制温暖但保留遗憾，色彩由冷蓝边光回到低饱和暖黄。"
      }
    ],
